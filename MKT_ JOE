// ─── Drag & Drop Hook ────────────────────────────────────────────────────────
function useDragDrop(onDrop) {
  const drag = useRef(null);
  const [over, setOver] = useState(null);

  const onDragStart = useCallback((e, pid, tid) => {
    drag.current = { pid, tid };
    e.dataTransfer.effectAllowed = "move";
    e.currentTarget.style.opacity = "0.4";
  }, []);

  const onDragEnd = useCallback((e) => {
    e.currentTarget.style.opacity = "1";
    setOver(null);
    drag.current = null;
  }, []);

  const onDragOver = useCallback((e, pid, tid) => {
    e.preventDefault();
    e.dataTransfer.dropEffect = "move";
    setOver({ pid, tid });
  }, []);

  const onDragLeave = useCallback(() => setOver(null), []);

  const onDropEl = useCallback((e, pid, tid) => {
    e.preventDefault();
    setOver(null);
    if (!drag.current) return;
    if (drag.current.pid === pid && drag.current.tid === tid) return;
    onDrop(drag.current, { pid, tid });
    drag.current = null;
  }, [onDrop]);

  // For kanban column drop (no target task)
  const onDropCol = useCallback((e, status) => {
    e.preventDefault();
    setOver(null);
    if (!drag.current) return;
    onDrop(drag.current, { status });
    drag.current = null;
  }, [onDrop]);

  return { onDragStart, onDragEnd, onDragOver, onDragLeave, onDropEl, onDropCol, over };
}

