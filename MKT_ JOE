function InlineSelect({value,options,onChange,renderOption,C}) {
  const [open,setOpen]=useState(false);
  const ref=useRef();
  useEffect(()=>{ const fn=e=>{ if(ref.current&&!ref.current.contains(e.target)) setOpen(false); }; document.addEventListener("mousedown",fn); return()=>document.removeEventListener("mousedown",fn); },[]);
  return (
    <div ref={ref} style={{position:"relative",display:"inline-block"}}>
      <div onClick={e=>{e.stopPropagation();setOpen(o=>!o);}} style={{cursor:"pointer",display:"flex",alignItems:"center",gap:4}}>
        {renderOption(value)}<Ic.Chevron c={C.textLight} up={open}/>
      </div>
      {open&&<div style={{position:"absolute",top:"calc(100% + 4px)",left:0,background:C.card,border:`0.5px solid ${C.border}`,borderRadius:4,zIndex:50,minWidth:140,boxShadow:`0 4px 16px ${C.shadow}`}}>
        {options.map(o=><div key={o} onClick={e=>{e.stopPropagation();onChange(o);setOpen(false);}} style={{padding:"8px 12px",cursor:"pointer",fontSize:12,color:C.textPrimary,display:"flex",alignItems:"center",justifyContent:"space-between",borderBottom:`0.5px solid ${C.border}`}}>
          {renderOption(o)}{value===o&&<Ic.Check c={C.accentLight} s={10}/>}
        </div>)}
      </div>}
    </div>
  );
}

// ─── Calendar View ───────────────────────────────────────────────────────────
function CalendarView({allTasks,C,onOpenTask,projects}) {
  const [cal,setCal]=useState(()=>{ const d=new Date(todayD); return {y:d.getFullYear(),m:d.getMonth()}; });
  const firstDay=new Date(cal.y,cal.m,1).getDay();
  const daysInMonth=new Date(cal.y,cal.m+1,0).getDate();
  const cells=Array.from({length:Math.ceil((firstDay+daysInMonth)/7)*7},(_,i)=>{
    const day=i-firstDay+1;
    return day>=1&&day<=daysInMonth ? day : null;
  });
  const tasksForDay=day=>{
    const ds=`${cal.y}-${String(cal.m+1).padStart(2,"0")}-${String(day).padStart(2,"0")}`;
    return allTasks.filter(t=>t.due===ds);
  };
  const todayNum=todayD.getFullYear()===cal.y&&todayD.getMonth()===cal.m?todayD.getDate():null;

  return (
    <div style={{padding:"0 24px 24px"}}>
      <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:14}}>
        <button onClick={()=>setCal(c=>{ const d=new Date(c.y,c.m-1); return {y:d.getFullYear(),m:d.getMonth()}; })} style={{background:"none",border:`0.5px solid ${C.border}`,borderRadius:3,cursor:"pointer",padding:"4px 8px",color:C.textMuted}}><Ic.Arr c={C.textMuted} left s={12}/></button>
        <span style={{fontSize:13,fontWeight:500,color:C.accentLight,letterSpacing:1,minWidth:100,textAlign:"center"}}>{MONTH_NAMES[cal.m]} {cal.y}</span>
        <button onClick={()=>setCal(c=>{ const d=new Date(c.y,c.m+1); return {y:d.getFullYear(),m:d.getMonth()}; })} style={{background:"none",border:`0.5px solid ${C.border}`,borderRadius:3,cursor:"pointer",padding:"4px 8px",color:C.textMuted}}><Ic.Arr c={C.textMuted} s={12}/></button>
        <button onClick={()=>setCal({y:todayD.getFullYear(),m:todayD.getMonth()})} style={{marginLeft:"auto",background:"none",border:`0.5px solid ${C.border}`,borderRadius:3,cursor:"pointer",padding:"4px 10px",fontSize:10,color:C.textMuted,letterSpacing:1}}>HOJE</button>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)",gap:1,background:C.border,borderRadius:4,overflow:"hidden"}}>
        {["Dom","Seg","Ter","Qua","Qui","Sex","Sáb"].map(d=>(
          <div key={d} style={{background:C.card2,padding:"6px 4px",textAlign:"center",fontSize:9,color:C.textMuted,letterSpacing:1,fontWeight:500}}>{d.toUpperCase()}</div>
        ))}
        {cells.map((day,i)=>{
          const tasks=day?tasksForDay(day):[];
          const isToday=day===todayNum;
          return (
            <div key={i} style={{background:isToday?C.accentDim:C.card,minHeight:72,padding:"6px 6px 4px",position:"relative"}}>
              {day&&<div style={{fontSize:10,fontWeight:isToday?600:400,color:isToday?C.accentLight:C.textMuted,marginBottom:4,textAlign:"right"}}>{day}</div>}
              {tasks.slice(0,3).map(t=>{
                const sc=C.statusC[t.status];
                const od=isOD(t.due)&&t.status!=="Concluído";
                return (
                  <div key={t.id} onClick={()=>{ const pr=projects.find(p=>p.tasks.find(tk=>tk.id===t.id)); if(pr) onOpenTask(t,pr.id); }} style={{background:od?C.overdueB:sc.bg,borderLeft:`2px solid ${od?C.overdue:sc.dot}`,padding:"2px 5px",borderRadius:2,marginBottom:3,cursor:"pointer",overflow:"hidden"}}>
                    <div style={{fontSize:9,color:od?C.overdue:sc.text,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",letterSpacing:.3}}>{t.title}</div>
                  </div>
                );
              })}
              {tasks.length>3&&<div style={{fontSize:8,color:C.textLight,letterSpacing:1}}>+{tasks.length-3}</div>}
            </div>
          );
        })}
      </div>
    </div>
  );
}

