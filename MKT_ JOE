                            <div style={{height:3,background:C.surface,borderRadius:2}}><div style={{height:3,borderRadius:2,background:dn===tot?C.statusC["Concluído"].dot:C.accent,width:`${pct}%`,transition:"width .3s"}}/></div>
                          </div>
                        ); })()}
                      </div>
                    );})}
                    <button onClick={()=>{ const pr=projects[0]; if(pr) openNewPanel(pr.id); }} style={{background:"none",border:`0.5px dashed ${C.border}`,borderRadius:4,padding:8,cursor:"pointer",color:C.textLight,fontSize:10,letterSpacing:1,display:"flex",alignItems:"center",justifyContent:"center",gap:4}}><Ic.Plus c={C.textLight} s={10}/>TAREFA</button>
                  </div>
                </div>
              );
            })}
          </div>
        )}

        {/* List */}
        {view==="list"&&filtered.map(pr=>(
          <div key={pr.id} style={{margin:"0 24px 10px",background:C.card,borderRadius:4,border:`0.5px solid ${C.border}`,overflow:"hidden"}}>
            <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"10px 14px",borderBottom:pr.collapsed?"none":`0.5px solid ${C.border}`,cursor:"pointer",background:C.card2}} onClick={()=>toggleC(pr.id)}>
              <div style={{display:"flex",alignItems:"center",gap:8}}>
                <Ic.Chevron c={C.textMuted} up={!pr.collapsed}/>
                <div>
                  <div style={{display:"flex",alignItems:"center",gap:7}}>
                    <span style={{fontWeight:500,fontSize:13,color:C.accentLight}}>{pr.name}</span>
                    <span style={{fontSize:9,color:C.textLight,letterSpacing:1}}>{pr.tasks.length} TAREFAS</span>
                  </div>
                  {pr.desc&&<div style={{fontSize:11,color:C.textMuted,marginTop:1}}>{pr.desc}</div>}
                </div>
              </div>
              <div style={{display:"flex",gap:4}} onClick={e=>e.stopPropagation()}>
                <button onClick={e=>openEditP(pr,e)} style={{background:"none",border:"none",cursor:"pointer",padding:3}}><Ic.Edit c={C.textMuted}/></button>
                <button onClick={e=>{e.stopPropagation();delProj(pr.id);}} style={{background:"none",border:"none",cursor:"pointer",padding:3}}><Ic.X c={C.textLight}/></button>
              </div>
            </div>
            {!pr.collapsed&&(<>
              <table style={{width:"100%",borderCollapse:"collapse",fontSize:12,tableLayout:"fixed"}}>
                <colgroup><col style={{width:"28%"}}/><col style={{width:"14%"}}/><col style={{width:"10%"}}/><col style={{width:"10%"}}/><col style={{width:"13%"}}/><col style={{width:"16%"}}/><col style={{width:"9%"}}/></colgroup>
                <thead><tr style={{background:C.bg}}>{["TAREFA","STATUS","PRIOR.","PRAZO","RESPONSÁVEL","ETIQUETAS",""].map(h=><th key={h} style={{padding:"6px 10px",textAlign:"left",color:C.textMuted,fontWeight:400,borderBottom:`0.5px solid ${C.border}`,fontSize:9,letterSpacing:1}}>{h}</th>)}</tr></thead>
                <tbody>{pr.tasks.map((task,ti)=>{ const od=isOD(task.due)&&task.status!=="Concluído"; const isOver=dnd.over?.tid===task.id; return (
                  <tr key={task.id}
                    draggable
                    onDragStart={e=>dnd.onDragStart(e,pr.id,task.id)}
                    onDragEnd={dnd.onDragEnd}
                    onDragOver={e=>dnd.onDragOver(e,pr.id,task.id)}
                    onDragLeave={dnd.onDragLeave}
                    onDrop={e=>dnd.onDropEl(e,pr.id,task.id)}
                    style={{background:od?(dark?"#1E0A0A":"#FFF5F5"):ti%2===0?C.card:C.card2,cursor:"grab",outline:isOver?`2px solid ${C.accentLight}`:"none",transition:"outline .1s"}}
                    onClick={()=>openPanel(task,pr.id)}>
                    <td style={{padding:"9px 10px",borderBottom:`0.5px solid ${C.border}`}}>
                      <div style={{display:"flex",alignItems:"center",gap:6}}>
                        <div style={{width:3,height:22,borderRadius:2,background:C.statusC[task.status]?.dot||C.border,flexShrink:0}}/>
                        <div style={{overflow:"hidden"}}>
                          <div style={{fontWeight:500,color:C.textPrimary,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{task.title}</div>
                          <div style={{display:"flex",gap:5,marginTop:2}}>
                            {task.script?.length>0&&<span style={{fontSize:9,color:C.textLight,display:"flex",alignItems:"center",gap:2}}><Ic.Script c={C.textLight} s={9}/>{task.script.length}</span>}
                            {task.links?.length>0&&<span style={{fontSize:9,color:C.textLight,display:"flex",alignItems:"center",gap:2}}><Ic.Link c={C.textLight} ca={C.textLight} s={9}/>{task.links.length}</span>}
                            {task.comments?.length>0&&<span style={{fontSize:9,color:C.textLight,display:"flex",alignItems:"center",gap:2}}><Ic.Chat c={C.textLight} s={9}/>{task.comments.length}</span>}
                            {task.subtasks?.length>0&&(()=>{ const dn=task.subtasks.filter(s=>s.done).length,tot=task.subtasks.length; return <span style={{fontSize:9,color:dn===tot?C.statusC["Concluído"].dot:C.textLight,display:"flex",alignItems:"center",gap:2}}><Ic.Task c={dn===tot?C.statusC["Concluído"].dot:C.textLight} s={9}/>{dn}/{tot}</span>; })()}
                          </div>
                        </div>
                      </div>
                    </td>
                    <td style={{padding:"9px 10px",borderBottom:`0.5px solid ${C.border}`}} onClick={e=>e.stopPropagation()}><StatusBadge status={task.status} pid={pr.id} tid={task.id} inline/></td>
                    <td style={{padding:"9px 10px",borderBottom:`0.5px solid ${C.border}`}} onClick={e=>e.stopPropagation()}><PriorityDot priority={task.priority} pid={pr.id} tid={task.id} inline/></td>
                    <td style={{padding:"9px 10px",borderBottom:`0.5px solid ${C.border}`}} onClick={e=>e.stopPropagation()}>
                      <span style={{fontSize:11,color:od?C.overdue:C.textMuted,display:"flex",alignItems:"center",gap:4,whiteSpace:"nowrap"}}>{od&&<Ic.Alert c={C.overdue} s={10}/>}{fmtDate(task.due)}</span>
                    </td>
                    <td style={{padding:"9px 10px",borderBottom:`0.5px solid ${C.border}`}}>
                      {task.owner?<div style={{display:"flex",alignItems:"center",gap:5}}><Avatar name={task.owner} idx={ownerIdx(task.owner)} size={20}/><span style={{fontSize:11,color:C.textMuted,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{task.owner}</span></div>:<span style={{color:C.textLight,fontSize:11}}>—</span>}
                    </td>
                    <td style={{padding:"9px 10px",borderBottom:`0.5px solid ${C.border}`}}>
                      <div style={{display:"flex",gap:3,flexWrap:"wrap"}}>
                        {(task.tags||[]).slice(0,2).map((tg,i)=><span key={tg} style={{padding:"1px 5px",borderRadius:2,fontSize:9,letterSpacing:.5,background:C.tagBg[i%C.tagBg.length],color:C.tagText[i%C.tagText.length],whiteSpace:"nowrap"}}>{tg.toUpperCase()}</span>)}
                        {(task.tags||[]).length>2&&<span style={{fontSize:9,color:C.textLight}}>+{task.tags.length-2}</span>}
                      </div>
                    </td>
                    <td style={{padding:"9px 10px",borderBottom:`0.5px solid ${C.border}`}}>
                      <button onClick={e=>{e.stopPropagation();delTask(pr.id,task.id);}} style={{background:"none",border:"none",cursor:"pointer",padding:2}}><Ic.X c={C.textLight} s={10}/></button>
                    </td>
                  </tr>
                );})}
                </tbody>
              </table>
              <button style={{background:"none",border:"none",color:C.accentLight,cursor:"pointer",fontSize:10,padding:"8px 14px",display:"flex",alignItems:"center",gap:5,letterSpacing:1}} onClick={()=>openNewPanel(pr.id)}><Ic.Plus c={C.accentLight} s={10}/>ADICIONAR TAREFA</button>
            </>)}
          </div>
        ))}
        {addingProj&&(
          <div style={{margin:"0 24px 10px",background:C.card,borderRadius:4,border:`0.5px solid ${C.border}`,padding:14}}>
            <div style={{fontSize:9,fontWeight:500,color:C.accentLight,marginBottom:10,letterSpacing:2}}>NOVO PROJETO</div>
            <input value={newProj.name} onChange={e=>setNewProj(f=>({...f,name:e.target.value}))} placeholder="Nome do projeto..." style={{...inp,marginBottom:7}}/>
            <input value={newProj.desc} onChange={e=>setNewProj(f=>({...f,desc:e.target.value}))} placeholder="Descrição..." style={{...inp,marginBottom:10}}/>
            <div style={{display:"flex",gap:8}}><button style={btn(true)} onClick={addProj}>Criar</button><button style={btn(false)} onClick={()=>setAddingProj(false)}>Cancelar</button></div>
          </div>
        )}
      </>)}

      {/* ══ DASHBOARD ══ */}
      {mainTab==="dashboard"&&(
        <div style={{padding:"12px 24px"}}>
          <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:10}}>
            <span style={{fontSize:10,fontWeight:500,color:C.accentLight,letterSpacing:3}}>RELATÓRIO DE TAREFAS</span>
            <div style={{display:"flex",gap:6}}>{["semanal","mensal"].map(r=><button key={r} onClick={()=>setDashRange(r)} style={{...btn(dashRange===r,true),letterSpacing:1,fontSize:9}}>{r.toUpperCase()}</button>)}</div>
          </div>
          <div style={{display:"flex",gap:8,marginBottom:10}}>
            {statCard(dashTasks.length,"PERÍODO",<Ic.Dash c={C.textMuted} s={11}/>)}
            {statCard(dashTasks.filter(t=>t.status==="Concluído").length,"CONCLUÍDAS",<Ic.Task c={C.textMuted} s={11}/>)}
            {statCard(dashTasks.filter(t=>t.status==="Em andamento").length,"ANDAMENTO",<Ic.Task c={C.textMuted} s={11}/>)}
            {statCard(stats.overdue,"VENCIDAS",<Ic.Alert c={stats.overdue>0?C.overdue:C.textMuted} s={11}/>)}
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:8}}>
            <div style={{background:C.card,borderRadius:4,border:`0.5px solid ${C.border}`,padding:12}}>
              <div style={{fontSize:9,color:C.accentLight,letterSpacing:2,marginBottom:4}}>CRIADAS — {dashRange==="semanal"?"7 DIAS":"4 SEMANAS"}</div>
              <BarChart data={dashRange==="semanal"?weekBar:monthBar} color={C.accent}/>
            </div>
            <div style={{background:C.card,borderRadius:4,border:`0.5px solid ${C.border}`,padding:12}}>
              <div style={{fontSize:9,color:C.accentLight,letterSpacing:2,marginBottom:10}}>STATUS GERAL</div>
              {STATUSES.map(s=>{ const cnt=allTasks.filter(t=>t.status===s).length; const pct=allTasks.length?Math.round(cnt/allTasks.length*100):0; const sc=C.statusC[s]; return (
                <div key={s} style={{marginBottom:8}}>
                  <div style={{display:"flex",justifyContent:"space-between",fontSize:10,color:C.textMuted,marginBottom:3}}><span style={{display:"flex",alignItems:"center",gap:5}}><span style={{width:5,height:5,borderRadius:"50%",background:sc.dot}}/>{s}</span><span>{cnt}</span></div>
                  <div style={{height:3,background:C.surface,borderRadius:2}}><div style={{height:3,background:sc.dot,borderRadius:2,width:`${pct}%`,transition:"width .4s"}}/></div>
                </div>
              );})}
            </div>
          </div>
          <div style={{background:C.card,borderRadius:4,border:`0.5px solid ${C.border}`,padding:12}}>
            <div style={{fontSize:9,color:C.accentLight,letterSpacing:2,marginBottom:10}}>DESEMPENHO POR RESPONSÁVEL</div>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
              <thead><tr>{["RESPONSÁVEL","TOTAL","CONCLUÍDAS","ANDAMENTO","A FAZER"].map(h=><th key={h} style={{padding:"5px 8px",textAlign:"left",color:C.textMuted,fontWeight:400,borderBottom:`0.5px solid ${C.border}`,fontSize:9,letterSpacing:1}}>{h}</th>)}</tr></thead>
              <tbody>{members.map((m,mi)=>{ const mt=allTasks.filter(t=>t.owner===m); if(!mt.length) return null; return (
                <tr key={m}>
                  <td style={{padding:"7px 8px",borderBottom:`0.5px solid ${C.border}`}}><div style={{display:"flex",alignItems:"center",gap:7}}><Avatar name={m} idx={mi} size={22}/><span style={{fontWeight:500,color:C.textPrimary,fontSize:12}}>{m}</span></div></td>
                  <td style={{padding:"7px 8px",borderBottom:`0.5px solid ${C.border}`,color:C.textMuted}}>{mt.length}</td>
                  {STATUSES.map(s=><td key={s} style={{padding:"7px 8px",borderBottom:`0.5px solid ${C.border}`}}><span style={{padding:"2px 7px",borderRadius:2,fontSize:9,background:C.statusC[s].bg,color:C.statusC[s].text}}>{mt.filter(t=>t.status===s).length}</span></td>)}
                </tr>
              );})}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* ══ MEMBROS ══ */}
      {mainTab==="membros"&&(
        <div style={{padding:"12px 24px"}}>
          <div style={{fontSize:9,color:C.accentLight,letterSpacing:3,marginBottom:10}}>GERENCIAR MEMBROS</div>
          <div style={{background:C.card,borderRadius:4,border:`0.5px solid ${C.border}`,overflow:"hidden",marginBottom:10}}>
            {members.map((m,i)=>(
              <div key={m} style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"11px 14px",borderBottom:`0.5px solid ${C.border}`,background:i%2===0?C.card:C.card2}}>
                {editingMember===i?(
                  <div style={{display:"flex",gap:8,flex:1,alignItems:"center"}}><Avatar name={m} idx={i} size={28}/><input autoFocus value={newMemberName} onChange={e=>setNewMemberName(e.target.value)} onKeyDown={e=>e.key==="Enter"&&saveMemberEdit()} style={{...inp,flex:1,padding:"5px 8px"}}/><button style={btn(true,true)} onClick={saveMemberEdit}>Salvar</button><button style={btn(false,true)} onClick={()=>setEditingMember(null)}>Cancelar</button></div>
                ):(
                  <>
                    <div style={{display:"flex",alignItems:"center",gap:10}}>
                      <Avatar name={m} idx={i} size={34}/>
                      <div><div style={{fontWeight:500,color:C.textPrimary,fontSize:13}}>{m}</div><div style={{fontSize:9,color:C.textMuted,marginTop:1,letterSpacing:1}}>{allTasks.filter(t=>t.owner===m).length} TAREFAS · {allTasks.filter(t=>t.owner===m&&t.status==="Concluído").length} CONCLUÍDAS</div></div>
                    </div>
                    <div style={{display:"flex",gap:4}}><button onClick={()=>{setEditingMember(i);setNewMemberName(m);}} style={{background:"none",border:"none",cursor:"pointer",padding:3}}><Ic.Edit c={C.textMuted}/></button><button onClick={()=>deleteMember(i)} style={{background:"none",border:"none",cursor:"pointer",padding:3}}><Ic.X c={C.textLight}/></button></div>
                  </>
                )}
              </div>
            ))}
          </div>
          <div style={{display:"flex",gap:8}}><input value={editingMember===null?newMemberName:""} onChange={e=>setNewMemberName(e.target.value)} onKeyDown={e=>e.key==="Enter"&&addMember()} placeholder="Nome do novo membro..." style={{...inp,flex:1}} onFocus={()=>setEditingMember(null)}/><button style={btn(true)} onClick={addMember}><Ic.Plus c="#F0DEC0" s={12}/>Adicionar</button></div>
        </div>
      )}

      {/* ══ ETIQUETAS ══ */}
      {mainTab==="etiquetas"&&(
        <div style={{padding:"12px 24px"}}>
          <div style={{fontSize:9,color:C.accentLight,letterSpacing:3,marginBottom:10}}>GERENCIAR ETIQUETAS</div>
          <div style={{background:C.card,borderRadius:4,border:`0.5px solid ${C.border}`,overflow:"hidden",marginBottom:10}}>
            {tags.map((tg,i)=>(
              <div key={tg} style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"10px 14px",borderBottom:`0.5px solid ${C.border}`,background:i%2===0?C.card:C.card2}}>
                {editingTag===i?(
                  <div style={{display:"flex",gap:8,flex:1,alignItems:"center"}}><input autoFocus value={newTagName} onChange={e=>setNewTagName(e.target.value)} onKeyDown={e=>e.key==="Enter"&&saveTagEdit()} style={{...inp,flex:1,padding:"5px 8px"}}/><button style={btn(true,true)} onClick={saveTagEdit}>Salvar</button><button style={btn(false,true)} onClick={()=>setEditingTag(null)}>Cancelar</button></div>
                ):(
                  <>
                    <div style={{display:"flex",alignItems:"center",gap:9}}><span style={{padding:"3px 9px",borderRadius:2,fontSize:9,letterSpacing:1,fontWeight:500,background:C.tagBg[i%C.tagBg.length],color:C.tagText[i%C.tagText.length]}}>{tg.toUpperCase()}</span><span style={{fontSize:11,color:C.textMuted}}>{allTasks.filter(t=>(t.tags||[]).includes(tg)).length} tarefas</span></div>
                    <div style={{display:"flex",gap:4}}><button onClick={()=>{setEditingTag(i);setNewTagName(tg);}} style={{background:"none",border:"none",cursor:"pointer",padding:3}}><Ic.Edit c={C.textMuted}/></button><button onClick={()=>deleteTag(i)} style={{background:"none",border:"none",cursor:"pointer",padding:3}}><Ic.X c={C.textLight}/></button></div>
                  </>
                )}
              </div>
            ))}
          </div>
          <div style={{display:"flex",gap:8}}><input value={editingTag===null?newTagName:""} onChange={e=>setNewTagName(e.target.value)} onKeyDown={e=>e.key==="Enter"&&addTag()} placeholder="Nova etiqueta..." style={{...inp,flex:1}} onFocus={()=>setEditingTag(null)}/><button style={btn(true)} onClick={addTag}><Ic.Plus c="#F0DEC0" s={12}/>Adicionar</button></div>
        </div>
      )}

      {/* ══ PAINEL LATERAL ══ */}
      {panel==="task"&&panelTask&&(
        <>
          <div onClick={()=>setPanel(null)} style={{position:"fixed",inset:0,background:"rgba(8,4,0,.4)",zIndex:60}}/>
          <div style={{position:"fixed",top:0,right:0,width:440,maxWidth:"96vw",height:"100vh",background:C.card,borderLeft:`0.5px solid ${C.border}`,zIndex:61,display:"flex",flexDirection:"column",boxShadow:`-8px 0 32px ${C.shadow}`}}>
            <div style={{padding:"14px 18px",borderBottom:`0.5px solid ${C.border}`,display:"flex",alignItems:"center",justifyContent:"space-between",background:C.card2,flexShrink:0}}>
              <span style={{fontSize:9,color:C.textMuted,letterSpacing:2}}>{panelTask.id?"EDITAR TAREFA":"NOVA TAREFA"}</span>
              <button onClick={()=>setPanel(null)} style={{background:"none",border:"none",cursor:"pointer",padding:3}}><Ic.X c={C.textMuted}/></button>
            </div>
            <div style={{padding:"12px 18px 0",flexShrink:0}}>
              <input value={panelTask.title||""} onChange={e=>setPanelTask(f=>({...f,title:e.target.value}))} placeholder="Nome da tarefa..." style={{width:"100%",padding:"0 0 10px",fontSize:15,fontWeight:500,background:"transparent",border:"none",outline:"none",color:C.textPrimary,boxSizing:"border-box",borderBottom:`0.5px solid ${C.border}`}}/>
            </div>
            <div style={{display:"flex",borderBottom:`0.5px solid ${C.border}`,paddingLeft:18,flexShrink:0,overflowX:"auto"}}>
              {[["details","Detalhes",null],["subtasks","Subtarefas",<Ic.Task c={taskTab==="subtasks"?C.accentLight:C.textMuted} s={11}/>],["script","Roteiro",<Ic.Script c={taskTab==="script"?C.accentLight:C.textMuted} s={11}/>],["links","Links",<Ic.Link c={taskTab==="links"?C.accentLight:C.textMuted} ca={taskTab==="links"?C.accentGold:C.textMuted} s={11}/>],["comments","Comentários",<Ic.Chat c={taskTab==="comments"?C.accentLight:C.textMuted} s={11}/>],["history","Histórico",<Ic.List c={taskTab==="history"?C.accentLight:C.textMuted} s={11}/>]].map(([t,l,icon])=>(
                <button key={t} style={tTab(taskTab===t)} onClick={()=>setTaskTab(t)}>
                  <span style={{display:"flex",alignItems:"center",gap:4}}>
                    {icon}{l}
                    {t==="comments"&&panelTask.comments?.length>0&&<span style={{background:C.accentDim,color:C.accentLight,fontSize:8,padding:"1px 5px",borderRadius:8,fontWeight:500}}>{panelTask.comments.length}</span>}
                    {t==="subtasks"&&panelTask.subtasks?.length>0&&<span style={{background:C.accentDim,color:C.accentLight,fontSize:8,padding:"1px 5px",borderRadius:8,fontWeight:500}}>{panelTask.subtasks.filter(s=>s.done).length}/{panelTask.subtasks.length}</span>}
                  </span>
                </button>
              ))}
                <button key={t} style={tTab(taskTab===t)} onClick={()=>setTaskTab(t)}><span style={{display:"flex",alignItems:"center",gap:4}}>{icon}{l}{t==="comments"&&panelTask.comments?.length>0&&<span style={{background:C.accentDim,color:C.accentLight,fontSize:8,padding:"1px 5px",borderRadius:8,fontWeight:500}}>{panelTask.comments.length}</span>}</span></button>
              ))}
            </div>
            <div style={{flex:1,overflowY:"auto",padding:"14px 18px"}}>
              {taskTab==="details"&&(
                <>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:12}}>
                    {[["STATUS","status",STATUSES],["PRIORIDADE","priority",PRIORITIES]].map(([lbl,key,opts])=>(
                      <div key={key}><label style={{display:"block",fontSize:9,color:C.textMuted,marginBottom:4,letterSpacing:1}}>{lbl}</label><select style={inp} value={panelTask[key]||opts[0]} onChange={e=>setPanelTask(f=>({...f,[key]:e.target.value}))}>{opts.map(o=><option key={o}>{o}</option>)}</select></div>
                    ))}
                    <div><label style={{display:"block",fontSize:9,color:C.textMuted,marginBottom:4,letterSpacing:1}}>PRAZO</label><input type="date" style={inp} value={panelTask.due||""} onChange={e=>setPanelTask(f=>({...f,due:e.target.value}))}/></div>
                    <div>
                      <label style={{display:"block",fontSize:9,color:C.textMuted,marginBottom:4,letterSpacing:1}}>RESPONSÁVEL</label>
                      <select style={inp} value={panelTask.owner||""} onChange={e=>setPanelTask(f=>({...f,owner:e.target.value}))}><option value="">—</option>{members.map(m=><option key={m}>{m}</option>)}</select>
                      {panelTask.owner&&<div style={{display:"flex",alignItems:"center",gap:7,marginTop:7}}><Avatar name={panelTask.owner} idx={ownerIdx(panelTask.owner)} size={24}/><span style={{fontSize:12,color:C.textMuted}}>{panelTask.owner}</span></div>}
                    </div>
                  </div>
                  <label style={{display:"block",fontSize:9,color:C.textMuted,marginBottom:7,letterSpacing:1}}>ETIQUETAS</label>
                  <div style={{display:"flex",flexWrap:"wrap",gap:5}}>
                    {tags.map((tg,i)=>{ const a=(panelTask.tags||[]).includes(tg); return <span key={tg} onClick={()=>togTag(tg)} style={{padding:"3px 9px",borderRadius:2,fontSize:9,letterSpacing:1,fontWeight:500,cursor:"pointer",background:a?C.tagBg[i%C.tagBg.length]:C.surface,color:a?C.tagText[i%C.tagText.length]:C.textMuted,border:`0.5px solid ${a?C.tagBg[i%C.tagBg.length]:C.border}`}}>{tg.toUpperCase()}</span>; })}
                  </div>
                </>
              )}
              {taskTab==="script"&&(
                <>
                  {!(panelTask.script?.length)&&<div style={{textAlign:"center",color:C.textLight,fontSize:11,padding:"28px 0",letterSpacing:1}}>NENHUM BLOCO. ADICIONE ABAIXO.</div>}
                  {(panelTask.script||[]).map((block,idx)=>(
                    <div key={block.id} style={{background:C.surface,borderRadius:3,padding:10,marginBottom:7,border:`0.5px solid ${C.border}`}}>
                      <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:7}}>
                        <span style={{width:6,height:6,borderRadius:1,background:{Ato:"#B87040",Cena:"#D4904A",Diálogo:"#70A870",Narração:"#7080A0"}[block.type],display:"inline-block"}}/>
                        <select value={block.type} onChange={e=>updBlock(block.id,"type",e.target.value)} style={{...inp,width:"auto",padding:"2px 6px",fontSize:10,letterSpacing:1}}>{BTYPES.map(t=><option key={t}>{t}</option>)}</select>
                        <div style={{display:"flex",gap:3,marginLeft:"auto"}}>
                          {[["N","bold"],["I","italic"],["U","underline"]].map(([l,f])=><button key={f} onClick={()=>updBlock(block.id,f,!block[f])} style={{width:19,height:19,borderRadius:2,border:`0.5px solid ${C.border}`,cursor:"pointer",background:block[f]?C.accent:C.card,color:block[f]?"#F0DEC0":C.textMuted,fontSize:9,fontWeight:700,display:"flex",alignItems:"center",justifyContent:"center",fontStyle:f==="italic"?"italic":"normal",textDecoration:f==="underline"?"underline":"none"}}>{l}</button>)}
                          <button onClick={()=>moveBlock(block.id,-1)} disabled={idx===0} style={{width:19,height:19,borderRadius:2,border:`0.5px solid ${C.border}`,cursor:"pointer",background:C.card,color:C.textMuted,fontSize:9,display:"flex",alignItems:"center",justifyContent:"center"}}>↑</button>
                          <button onClick={()=>moveBlock(block.id,1)} disabled={idx===(panelTask.script.length-1)} style={{width:19,height:19,borderRadius:2,border:`0.5px solid ${C.border}`,cursor:"pointer",background:C.card,color:C.textMuted,fontSize:9,display:"flex",alignItems:"center",justifyContent:"center"}}>↓</button>
                          <button onClick={()=>delBlock(block.id)} style={{width:19,height:19,borderRadius:2,border:`0.5px solid ${C.border}`,cursor:"pointer",background:C.card,display:"flex",alignItems:"center",justifyContent:"center"}}><Ic.X c={C.textLight} s={9}/></button>
                        </div>
                      </div>
                      <textarea value={block.content} onChange={e=>updBlock(block.id,"content",e.target.value)} placeholder={`${block.type}...`} rows={2} style={{...inp,resize:"vertical",fontStyle:block.italic?"italic":"normal",fontWeight:block.bold?"500":"400",textDecoration:block.underline?"underline":"none",lineHeight:1.6,fontSize:12}}/>
                    </div>
                  ))}
                  <button onClick={addBlock} style={{...btn(false),width:"100%",marginTop:4,borderStyle:"dashed",justifyContent:"center",letterSpacing:1,fontSize:10}}><Ic.Plus c={C.textMuted} s={10}/>BLOCO</button>
                </>
              )}
              {taskTab==="links"&&(
                <>
                  {!(panelTask.links?.length)&&<div style={{textAlign:"center",color:C.textLight,fontSize:11,padding:"28px 0",letterSpacing:1}}>NENHUM LINK. ADICIONE ABAIXO.</div>}
                  {(panelTask.links||[]).map(link=>(
                    <div key={link.id} style={{background:C.surface,borderRadius:3,padding:10,marginBottom:7,border:`0.5px solid ${C.border}`}}>
                      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}><span style={{display:"flex",alignItems:"center",gap:4,fontSize:9,color:C.accentLight,letterSpacing:2}}><Ic.Link c={C.accentLight} ca={C.accentGold} s={10}/>LINK</span><button onClick={()=>delLink(link.id)} style={{background:"none",border:"none",cursor:"pointer",padding:2}}><Ic.X c={C.textLight} s={10}/></button></div>
                      <input value={link.url}   onChange={e=>updLink(link.id,"url",e.target.value)}   placeholder="https://..." style={{...inp,marginBottom:5,fontSize:12}}/>
                      <input value={link.title} onChange={e=>updLink(link.id,"title",e.target.value)} placeholder="Título" style={{...inp,marginBottom:5,fontSize:12}}/>
                      <input value={link.desc}  onChange={e=>updLink(link.id,"desc",e.target.value)}  placeholder="Descrição (opcional)" style={{...inp,fontSize:12}}/>
                    </div>
                  ))}
                  <button onClick={addLink} style={{...btn(false),width:"100%",marginTop:4,borderStyle:"dashed",justifyContent:"center",letterSpacing:1,fontSize:10}}><Ic.Plus c={C.textMuted} s={10}/>LINK</button>
                </>
              )}
              {taskTab==="subtasks"&&(
                <div>
                  {/* Progress bar */}
                  {panelTask.subtasks?.length>0&&(()=>{
                    const done=(panelTask.subtasks||[]).filter(s=>s.done).length;
                    const total=panelTask.subtasks.length;
                    const pct=Math.round(done/total*100);
                    return (
                      <div style={{marginBottom:16}}>
                        <div style={{display:"flex",justifyContent:"space-between",fontSize:10,color:C.textMuted,marginBottom:5,letterSpacing:1}}>
                          <span>{done} DE {total} CONCLUÍDAS</span>
                          <span style={{color:pct===100?C.statusC["Concluído"].dot:C.accentLight,fontWeight:500}}>{pct}%</span>
                        </div>
                        <div style={{height:4,background:C.surface,borderRadius:2}}>
                          <div style={{height:4,borderRadius:2,background:pct===100?C.statusC["Concluído"].dot:C.accent,width:`${pct}%`,transition:"width .3s"}}/>
                        </div>
                      </div>
                    );
                  })()}

                  {/* Subtask list */}
                  <div style={{display:"flex",flexDirection:"column",gap:4,marginBottom:12}}>
                    {!(panelTask.subtasks?.length)&&<div style={{textAlign:"center",color:C.textLight,fontSize:11,padding:"20px 0",letterSpacing:1}}>NENHUMA SUBTAREFA. ADICIONE ABAIXO.</div>}
                    {(panelTask.subtasks||[]).map((sub)=>(
                      <div key={sub.id} style={{display:"flex",alignItems:"center",gap:8,padding:"7px 10px",borderRadius:3,background:sub.done?C.surface:C.card2,border:`0.5px solid ${C.border}`,transition:"background .15s"}}>
                        <div style={{cursor:"pointer",flexShrink:0}} onClick={()=>toggleSub(sub.id)}>
                          <Ic.Check2 c={C.textMuted} filled={sub.done} C={C} s={16}/>
                        </div>
                        {editingSub===sub.id ? (
                          <input autoFocus value={editingSubText} onChange={e=>setEditingSubText(e.target.value)}
                            onBlur={()=>{ renameSub(sub.id,editingSubText||sub.text); setEditingSub(null); }}
                            onKeyDown={e=>{ if(e.key==="Enter"){ renameSub(sub.id,editingSubText||sub.text); setEditingSub(null); } if(e.key==="Escape") setEditingSub(null); }}
                            style={{...inp,flex:1,padding:"2px 6px",fontSize:12,background:"transparent"}}/>
                        ):(
                          <span onDoubleClick={()=>{ setEditingSub(sub.id); setEditingSubText(sub.text); }}
                            style={{flex:1,fontSize:12,color:sub.done?C.textMuted:C.textPrimary,textDecoration:sub.done?"line-through":"none",cursor:"text",lineHeight:1.4}}>{sub.text}</span>
                        )}
                        <button onClick={()=>delSub(sub.id)} style={{background:"none",border:"none",cursor:"pointer",padding:2,flexShrink:0,opacity:.5}}><Ic.X c={C.textLight} s={10}/></button>
                      </div>
                    ))}
                  </div>

                  {/* Add subtask */}
                  <div style={{display:"flex",gap:6}}>
                    <input
                      value={newSubText}
                      onChange={e=>setNewSubText(e.target.value)}
                      onKeyDown={e=>e.key==="Enter"&&addSub()}
                      placeholder="Nova subtarefa... (Enter para adicionar)"
                      style={{...inp,flex:1,fontSize:12}}
                    />
                    <button style={btn(true,true)} onClick={addSub}><Ic.Plus c="#F0DEC0" s={11}/></button>
                  </div>
                </div>
              )}
              {taskTab==="history"&&(
                <div>
                  {!(panelTask.history?.length)&&<div style={{textAlign:"center",color:C.textLight,fontSize:11,padding:"28px 0",letterSpacing:1}}>NENHUMA ALTERAÇÃO REGISTRADA.</div>}
                  <div style={{position:"relative"}}>
                    {panelTask.history?.length>0&&<div style={{position:"absolute",left:10,top:4,bottom:4,width:"0.5px",background:C.border}}/>}
                    {[...(panelTask.history||[])].reverse().map((h,i)=>(
                      <div key={h.id} style={{display:"flex",gap:12,marginBottom:12,position:"relative"}}>
                        <div style={{width:20,height:20,borderRadius:"50%",background:h.field==="created"?C.accentDim:C.surface,border:`0.5px solid ${h.field==="created"?C.accentLight:C.border}`,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0,zIndex:1}}>
                          {h.field==="created"
                            ? <Ic.Plus c={C.accentLight} s={9}/>
                            : <div style={{width:5,height:5,borderRadius:"50%",background:C.accentLight}}/>}
                        </div>
                        <div style={{flex:1,background:C.surface,borderRadius:3,padding:"8px 10px",border:`0.5px solid ${C.border}`}}>
                          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:h.field==="created"?0:5}}>
                            <span style={{fontSize:10,fontWeight:500,color:C.textPrimary}}>
                              {h.field==="created" ? `Tarefa criada` : FIELD_LABELS[h.field]||h.field}
                            </span>
                            <span style={{fontSize:9,color:C.textLight,letterSpacing:.5}}>{h.ts}</span>
                          </div>
                          {h.field!=="created"&&(
                            <div style={{display:"flex",alignItems:"center",gap:6,flexWrap:"wrap"}}>
                              <span style={{fontSize:11,color:C.textMuted,textDecoration:"line-through"}}>{h.oldVal}</span>
                              <span style={{fontSize:9,color:C.textLight}}>→</span>
                              <span style={{fontSize:11,color:C.accentLight,fontWeight:500}}>{h.newVal}</span>
                            </div>
                          )}
                          <div style={{fontSize:9,color:C.textLight,marginTop:4,letterSpacing:1}}>{h.author.toUpperCase()}</div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
                <>
                  <div style={{display:"flex",flexDirection:"column",gap:8,marginBottom:14}}>
                    {!(panelTask.comments?.length)&&<div style={{textAlign:"center",color:C.textLight,fontSize:11,padding:"20px 0",letterSpacing:1}}>NENHUM COMENTÁRIO AINDA.</div>}
                    {(panelTask.comments||[]).map(c=>(
                      <div key={c.id} style={{background:C.surface,borderRadius:3,padding:10,border:`0.5px solid ${C.border}`}}>
                        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:6}}>
                          <div style={{display:"flex",alignItems:"center",gap:7}}>
                            <Avatar name={c.author} idx={members.indexOf(c.author)} size={22}/>
                            <span style={{fontSize:11,fontWeight:500,color:C.textPrimary}}>{c.author}</span>
                            <span style={{fontSize:9,color:C.textLight,letterSpacing:.5}}>{c.ts}</span>
                          </div>
                          <button onClick={()=>delComment(c.id)} style={{background:"none",border:"none",cursor:"pointer",padding:2}}><Ic.X c={C.textLight} s={10}/></button>
                        </div>
                        <div style={{fontSize:12,color:C.textMuted,lineHeight:1.5}}>{c.text}</div>
                      </div>
                    ))}
                  </div>
                  <div style={{background:C.surface,borderRadius:3,padding:10,border:`0.5px solid ${C.border}`}}>
                    <select value={commentAuthor} onChange={e=>setCommentAuthor(e.target.value)} style={{...inp,marginBottom:7,fontSize:11}}>
                      <option value="">Anônimo</option>
                      {members.map(m=><option key={m}>{m}</option>)}
                    </select>
                    <textarea value={commentText} onChange={e=>setCommentText(e.target.value)} placeholder="Escreva um comentário..." rows={3} style={{...inp,resize:"none",fontSize:12,lineHeight:1.5,marginBottom:7}} onKeyDown={e=>{ if(e.key==="Enter"&&(e.metaKey||e.ctrlKey)) addComment(); }}/>
                    <button onClick={addComment} style={{...btn(true),width:"100%",justifyContent:"center",letterSpacing:1,fontSize:10}}><Ic.Send c="#F0DEC0" s={11}/>COMENTAR</button>
                  </div>
                </>
              )}
            </div>
            <div style={{padding:"10px 18px",borderTop:`0.5px solid ${C.border}`,display:"flex",justifyContent:"flex-end",gap:8,background:C.card2,flexShrink:0}}>
              <button style={btn(false)} onClick={()=>setPanel(null)}>Cancelar</button>
              <button style={btn(true)} onClick={savePanel}><Ic.Check c="#F0DEC0" s={11}/>Salvar</button>
            </div>
          </div>
        </>
      )}

      {/* MODAL PROJETO */}
      {modal==="project"&&(
        <div style={{position:"fixed",inset:0,background:"rgba(8,4,0,.5)",display:"flex",alignItems:"center",justifyContent:"center",zIndex:70}} onClick={()=>setModal(null)}>
          <div style={{background:C.card,borderRadius:4,width:400,maxWidth:"92vw",border:`0.5px solid ${C.border}`,padding:22}} onClick={e=>e.stopPropagation()}>
            <div style={{fontSize:9,fontWeight:500,color:C.accentLight,marginBottom:12,letterSpacing:2}}>EDITAR PROJETO</div>
            <label style={{display:"block",fontSize:9,color:C.textMuted,marginBottom:4,letterSpacing:1}}>NOME</label>
            <input style={{...inp,marginBottom:10}} value={modalForm.name||""} onChange={e=>setModalForm(f=>({...f,name:e.target.value}))}/>
            <label style={{display:"block",fontSize:9,color:C.textMuted,marginBottom:4,letterSpacing:1}}>DESCRIÇÃO</label>
            <textarea rows={3} style={{...inp,resize:"vertical",marginBottom:14}} value={modalForm.desc||""} onChange={e=>setModalForm(f=>({...f,desc:e.target.value}))}/>
            <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}><button style={btn(false)} onClick={()=>setModal(null)}>Cancelar</button><button style={btn(true)} onClick={saveProj}>Salvar</button></div>
          </div>
        </div>
      )}

      <Toast msg={toast} C={C}/>
    </div>
  );
}
